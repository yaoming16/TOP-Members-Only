<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="./styles/index.css" />
    <link rel="stylesheet" href="./styles/form.css" />
    <script src="/scripts/login.js" type="module" defer></script>
    <script src="/scripts/logout.js" type="module" defer></script>
    <title>The Latin Quarter - Log In</title>
  </head>
  <body>
    <%- include("./elements/nav.ejs") %>
    <main>
      <div class="container">
        <h1 class="center">The Latin Quarter</h1>
        <form id="loginForm">
          <fieldset>
            <legend>Log In</legend>
            <div class="inputDiv">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                aria-describedby="emailError"
              />
              <p id="emailError" class="errorMsg" aria-live="polite"></p>
            </div>
            <div class="inputDiv">
              <label for="password">Password</label>
              <input
                id="password"
                name="password"
                type="password"
                aria-describedby="passwordError"
              />
              <p id="passwordError" class="errorMsg" aria-live="polite"></p>
            </div>
          </fieldset>
          <button type="submit" class="bigBtn">Log In</button>
        </form>
      </div>
    </main>
    <%- include("./elements/footer.ejs") %>
  </body>
</html>
