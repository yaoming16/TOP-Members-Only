<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="./styles/index.css" />
    <link rel="stylesheet" href="./styles/form.css" />
    <script src="/scripts/login.js" type="module" defer></script>
    <script src="/scripts/logout.js" type="module" defer></script>
    <title>The Latin Quarter - Log In</title>
  </head>
  <%- include("./elements/nav.ejs") %>
  <body>
    <main>
      <div class="container">
        <h1 class="center">The Latin Quarter</h1>
        <form id="loginForm">
          <fieldset>
            <legend>Log In</legend>
            <div class="inputDiv">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" />
              <p id="emailError" class="errorMsg"></p>
            </div>
            <div class="inputDiv">
              <label for="password">Password</label>
              <input id="password" name="password" type="password" />
              <p id="passwordError" class="errorMsg"></p>
            </div>
          </fieldset>
          <button type="submit" class="bigBtn">Log In</button>
        </form>
      </div>
    </main>
  </body>
</html>
