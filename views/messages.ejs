<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="/scripts/messages.js" type="module" defer></script>
    <title>Members Only - Messages</title>
  </head>
  <body>
    <main>
      <h1>Members Messages</h1>
      <% if (locals.currentUser) { %>
      <button id="addMessageBtn">Add New Message</button>
      <%- include("./elements/addModal.ejs") %>
      <% } %>
      <ul id="messagesContainer">
        <% messages.forEach((message) => { %>
        <li><%- include("./elements/card.ejs", {message: message}) %></li>
        <%}) %>
      </ul>
    </main>
  </body>
</html>
